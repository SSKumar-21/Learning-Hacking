<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Student Login</title>

    <link rel="stylesheet" href="/style.css">

    <!-- Google Font -->
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">

    <!-- Font Awesome -->
    <link rel="stylesheet"
        href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.1/css/all.min.css">
</head>

<body>

<div class="background"></div>

<div class="login-card">

    <div class="logo">
        <i class="fa-solid fa-user-graduate"></i>
    </div>

    <h1>Student Login</h1>

    <p>Sign in using your Email and Roll Number</p>

    <form action="/login" method="POST">

        <!-- Email -->

        <div class="input-box">
            <i class="fa-solid fa-envelope"></i>

            <input
                type="text"
                name="email"
                placeholder="Enter Email"
                required>
        </div>

        <!-- Roll Number -->

        <div class="input-box">
            <i class="fa-solid fa-id-card"></i>

            <input
                type="password"
                name="password"
                placeholder="Enter Roll Number"
                required>
        </div>

        <div class="options">

            <label>
                <input type="checkbox">
                Remember Me
            </label>

            <a href="#">Forgot Roll Number?</a>

        </div>

        <button type="submit">
            Login
        </button>

        <% if (error) { %>

            <div style="
                margin-top:20px;
                background:#ffebee;
                color:#c62828;
                padding:12px;
                border-radius:8px;
                text-align:center;
                font-weight:600;
            ">
                <i class="fa-solid fa-circle-exclamation"></i>
                <%= error %>
            </div>

        <% } %>

    </form>

</div>

</body>
</html>